# ── Google Gemini via Vertex AI ──────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# ── Google Service Account ───────────────────────────────────────────────────
# For Railway: set this to the base64 output of encode_service_account.py.
# For local dev: leave empty and place service_account.json in the project root.
SERVICE_ACCOUNT_JSON=ewogICJ0eXBlI...

# ── Google Sheets ────────────────────────────────────────────────────────────
SPREADSHEET_ID=1xp7SLZiqzHKamIh0P4WCYu3K0tsP0dFbxQjjyQOStig

# ── Google Calendar ──────────────────────────────────────────────────────────
CALENDAR_ID=primary

# ── CV attachment (output of encode_cv.py) ───────────────────────────────────
CV_BASE64=JVBERi0x...   # base64-encoded PDF

# ── Behaviour settings ───────────────────────────────────────────────────────
MAX_COMPANIES_PER_DAY=5
FOLLOW_UP_DAYS=14

# Set to "true" ONLY when you're happy with the quality of the drafts
AUTO_SEND=false
